@ECHO OFF

SET BACKUPDIR=%1

IF NOT EXIST "%BACKUPDIR%" (
  ECHO Invalid directory: %BACKUPDIR%
  ECHO Syntax: sql-server-restore.bat ^<backup-directory^>  
  EXIT /b
)

net stop SQLServerAgent
net stop MSSQLSERVER && timeout /t 5 /nobreak >nul
net start MSSQLSERVER && timeout /t 5 /nobreak >nul

SET DBNAME=msdb
SET FILEPATH=%BACKUPDIR%\%DBNAME%.bak
sqlcmd -E -C -Q "ALTER DATABASE %DBNAME% SET SINGLE_USER WITH ROLLBACK IMMEDIATE; RESTORE DATABASE %DBNAME% FROM DISK = '%FILEPATH%' WITH RECOVERY, REPLACE; ALTER DATABASE %DBNAME% SET MULTI_USER"
ECHO.

SET DBNAME=model
SET FILEPATH=%BACKUPDIR%\%DBNAME%.bak
sqlcmd -E -C -Q "ALTER DATABASE %DBNAME% SET SINGLE_USER WITH ROLLBACK IMMEDIATE; RESTORE DATABASE %DBNAME% FROM DISK = '%FILEPATH%' WITH RECOVERY, REPLACE; ALTER DATABASE %DBNAME% SET MULTI_USER"
ECHO.

SET DBNAME=tools
