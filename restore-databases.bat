ECHO.

net stop MSSQLSERVER && timeout /t 5 /nobreak >nul
net start MSSQLSERVER /m && timeout /t 5 /nobreak >nul

SET DBNAME=master
SET FILEPATH=%BACKUPDIR%\%DBNAME%.bak
sqlcmd -E -C -Q "RESTORE DATABASE %DBNAME% FROM DISK = '%FILEPATH%' WITH RECOVERY, REPLACE" && timeout /t 5 /nobreak >nul
ECHO.

net stop MSSQLSERVER && timeout /t 5 /nobreak >nul
net start MSSQLSERVER && timeout /t 5 /nobreak >nul
net start SQLServerAgent
